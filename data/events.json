{
  "events": [
    {
      "id": "songpo_laoren",
      "name": "送魄老人",
      "title": "送魄老人",
      "layer": 1,
      "description": "路边有个老人坐在棺材旁，神色平静。他一辈子都在替别人送终，如今却没有人来送他。他看着你，说：「渡魂人，你能替我做一件事吗？」",
      "choices": [
        {
          "text": "「我愿意听你说完。」",
          "result": {
            "type": "card_reward",
            "card_id": "ci_bei_gan_hua",
            "description": "老人将一张牌递给你，那是他一生的慈悲。获得「慈悲感化」"
          }
        },
        {
          "text": "「我会替你找一个送行的人。」",
          "result": {
            "type": "multi",
            "effects": [
              {"type": "gold", "value": 30},
              {"type": "emotion_gain", "emotion": "grief", "value": 1}
            ],
            "description": "你找来了村里最后一个认识他的人。获得30金币，+悲1"
          }
        },
        {
          "text": "「抱歉，我还有要紧的事。」",
          "result": {
            "type": "emotion_gain",
            "emotion": "calm",
            "value": 1,
            "description": "你学会了有时候放手也是一种渡化。+定1"
          }
        }
      ]
    },

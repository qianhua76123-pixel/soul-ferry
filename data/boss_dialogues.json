{
  "shuigui_wanggui": {
    "ruan_ruyue": {
      "purification": {
        "trigger": {"grief": 3},
        "phases": [
          {
            "speaker": "阮如月",
            "text": "你叫望归……你在等谁回来？",
            "emotion_change": {},
            "pause_after": 0.6
          },
          {
            "speaker": "水鬼·望归",
            "text": "……等、等我的孩子。他说去赶集，说回来给我带糖……",
            "emotion_change": {"grief": 1},
            "pause_after": 0.5
          },
          {
            "speaker": "阮如月",
            "text": "他回来过。我在村子里看到他的牌位了。他等了你很多年。",
            "emotion_change": {},
            "pause_after": 0.8
          },
          {
            "speaker": "水鬼·望归",
            "text": "……牌位？那孩子……他……他也走了……",
            "emotion_change": {"grief": 1},
            "pause_after": 0.6
          },
          {
            "speaker": "阮如月",
            "text": "你们会在那边相见的。别再守着这滩水了，他在等你。",
            "emotion_change": {},
            "pause_after": 1.0
          },
          {
            "speaker": "水鬼·望归",
            "text": "……好……好。我不等了……",
            "emotion_change": {},
            "pause_after": 0.4
          }
        ],
        "completion_effect": "purification_complete"
      },
      "suppression": {
        "phases": [
          {
            "speaker": "阮如月",
            "text": "你执念太深，无法渡化。只能镇压了。",
            "emotion_change": {},
            "pause_after": 0.4
          }
        ],
        "completion_effect": "battle_victory"
      }
    },
    "shen_tiejun": {
      "purification": {
        "trigger": {"calm": 3, "grief": 2},
        "phases": [
          {
            "speaker": "沈铁钧",
            "text": "老鬼，你这辈子是等一个人？",
            "emotion_change": {},
            "pause_after": 0.5
          },
          {
            "speaker": "水鬼·望归",
            "text": "……我儿子。赶集去了……一直没回……",
            "emotion_change": {"grief": 1},
            "pause_after": 0.5
          },
          {
            "speaker": "沈铁钧",
            "text": "（沉默片刻）我查过村里的卷宗。你儿子三十年前因病去了。他没忘记你。",
            "emotion_change": {},
            "pause_after": 0.9
          },
          {
            "speaker": "水鬼·望归",
            "text": "……三十年……那孩子……唉……",
            "emotion_change": {},
            "pause_after": 0.7
          },
          {
            "speaker": "沈铁钧",
            "text": "去吧。阴间没有等待，只有相聚。",
            "emotion_change": {},
            "pause_after": 0.5
          }
        ],
        "completion_effect": "purification_complete"
      },
      "suppression": {
        "phases": [
          {
            "speaker": "沈铁钧",
            "text": "执念不退，那就只能走了。",
            "emotion_change": {},
            "pause_after": 0.3
          }
        ],
        "completion_effect": "battle_victory"
      }
    }
  },

  "hanba_jiaoge": {
    "ruan_ruyue": {
      "purification": {
        "trigger": {"calm": 2, "rage": 2},
        "phases": [
          {
            "speaker": "旱魃·焦骨",
            "text": "走开！！你们这些人从来不信我！从来都是烧我、埋我——",
            "emotion_change": {"rage": 1},
            "pause_after": 0.4
          },
          {
            "speaker": "阮如月",
            "text": "我信你。旱灾那年，是你挡住了东边那条河。村里的老人都记得。",
            "emotion_change": {},
            "pause_after": 0.8
          },
          {
            "speaker": "旱魃·焦骨",
            "text": "……你说什么。",
            "emotion_change": {},
            "pause_after": 0.6
          },
          {
            "speaker": "阮如月",
            "text": "你当时是想救人，对吗？不是带来旱灾——是想挡住洪水。",
            "emotion_change": {},
            "pause_after": 0.7
          },
          {
            "speaker": "旱魃·焦骨",
            "text": "……他们烧了我……活活的……我是想救他们……",
            "emotion_change": {"grief": 1},
            "pause_after": 1.0
          },
          {
            "speaker": "阮如月",
            "text": "我相信你。现在你可以放下了。",
            "emotion_change": {},
            "pause_after": 0.5
          }
        ],
        "completion_effect": "purification_complete"
      },
      "suppression": {
        "phases": [
          {
            "speaker": "阮如月",
            "text": "你的怒气太重，我没有办法靠近你的心。只能这样了。",
            "emotion_change": {},
            "pause_after": 0.4
          }
        ],
        "completion_effect": "battle_victory"
      }
    },
    "shen_tiejun": {
      "purification": {
        "trigger": {"calm": 3},
        "phases": [
          {
            "speaker": "沈铁钧",
            "text": "你的案子我重新翻过了。当年的判决是错的。",
            "emotion_change": {},
            "pause_after": 0.6
          },
          {
            "speaker": "旱魃·焦骨",
            "text": "……错的？六十年了才来说错的？！",
            "emotion_change": {"rage": 1},
            "pause_after": 0.4
          },
          {
            "speaker": "沈铁钧",
            "text": "是。我没有办法替他们道歉，但这案子的黑锅，你不该背。",
            "emotion_change": {},
            "pause_after": 0.8
          },
          {
            "speaker": "旱魃·焦骨",
            "text": "……（很久的沉默）……六十年……",
            "emotion_change": {},
            "pause_after": 1.2
          },
          {
            "speaker": "沈铁钧",
            "text": "去吧。",
            "emotion_change": {},
            "pause_after": 0.3
          }
        ],
        "completion_effect": "purification_complete"
      },
      "suppression": {
        "phases": [
          {
            "speaker": "沈铁钧",
            "text": "怒气不退，那这一关就只能硬过了。",
            "emotion_change": {},
            "pause_after": 0.3
          }
        ],
        "completion_effect": "battle_victory"
      }
    }
  },

  "guixiniang_sujin": {
    "ruan_ruyue": {
      "purification": {
        "trigger": {"joy": 3},
        "phases": [
          {
            "speaker": "鬼新娘·素锦",
            "text": "喜服穿好了……喜烛也点了……他怎么还不来……",
            "emotion_change": {},
            "pause_after": 0.7
          },
          {
            "speaker": "阮如月",
            "text": "素锦，你最喜欢的是什么颜色的花？",
            "emotion_change": {},
            "pause_after": 0.5
          },
          {
            "speaker": "鬼新娘·素锦",
            "text": "……什么？我……我喜欢栀子花。白色的，有香味……",
            "emotion_change": {"joy": 1},
            "pause_after": 0.6
          },
          {
            "speaker": "阮如月",
            "text": "你以前是个很爱笑的人，对吗？不只是为了他——是你自己就喜欢笑。",
            "emotion_change": {},
            "pause_after": 0.8
          },
          {
            "speaker": "鬼新娘·素锦",
            "text": "……我……我是……我以前常去河边看夕阳……那时候……",
            "emotion_change": {"joy": 1},
            "pause_after": 0.8
          },
          {
            "speaker": "阮如月",
            "text": "那个爱看夕阳的素锦，比喜服更美。去吧，那边的夕阳不会等人的。",
            "emotion_change": {},
            "pause_after": 1.0
          },
          {
            "speaker": "鬼新娘·素锦",
            "text": "……（轻声）……好。",
            "emotion_change": {},
            "pause_after": 0.5
          }
        ],
        "completion_effect": "purification_complete"
      },
      "suppression": {
        "phases": [
          {
            "speaker": "阮如月",
            "text": "你的喜悦已经扭曲成了执念。我没有办法打开你的心，只能把你镇住了。",
            "emotion_change": {},
            "pause_after": 0.5
          }
        ],
        "completion_effect": "battle_victory"
      }
    },
    "shen_tiejun": {
      "purification": {
        "trigger": {"calm": 2, "joy": 1},
        "phases": [
          {
            "speaker": "沈铁钧",
            "text": "那个人……是你自己选的，还是家里定的？",
            "emotion_change": {},
            "pause_after": 0.5
          },
          {
            "speaker": "鬼新娘·素锦",
            "text": "……自己……自己喜欢的……他会吹箫……",
            "emotion_change": {"joy": 1},
            "pause_after": 0.6
          },
          {
            "speaker": "沈铁钧",
            "text": "喜欢就是喜欢过了。不用等他来接。",
            "emotion_change": {},
            "pause_after": 0.7
          },
          {
            "speaker": "鬼新娘·素锦",
            "text": "……（沉默）……我可以……不等了？",
            "emotion_change": {},
            "pause_after": 0.8
          },
          {
            "speaker": "沈铁钧",
            "text": "可以。这一套衣服穿得很好看。去吧。",
            "emotion_change": {},
            "pause_after": 0.4
          }
        ],
        "completion_effect": "purification_complete"
      },
      "suppression": {
        "phases": [
          {
            "speaker": "沈铁钧",
            "text": "执念太深，打散了再说。",
            "emotion_change": {},
            "pause_after": 0.3
          }
        ],
        "completion_effect": "battle_victory"
      }
    }
  }
}

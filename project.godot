; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="渡魂录 SOUL FERRY"
config/description="中式民俗 · 情绪构筑 · Roguelite
「你是游走乡间的渡魂人，用情绪作为武器与货币，替走不掉的人了结执念。」"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/placeholder/icon.png"

[autoload]

ThemeSetup="*res://scripts/autoload/ThemeSetup.gd"
EmotionManager="*res://scripts/autoload/EmotionManager.gd"
CardDatabase="*res://scripts/autoload/CardDatabase.gd"
DeckManager="*res://scripts/autoload/DeckManager.gd"
GameState="*res://scripts/autoload/GameState.gd"
RelicManager="*res://scripts/autoload/RelicManager.gd"
BuffManager="*res://scripts/autoload/BuffManager.gd"
SoundManager="*res://scripts/autoload/SoundManager.gd"
TransitionManager="*res://scripts/autoload/TransitionManager.gd"
PauseMenu="*res://scripts/autoload/PauseMenu.gd"
AchievementManager="*res://scripts/autoload/AchievementManager.gd"
WumianManager="*res://scripts/autoload/WumianManager.gd"
CoopManager="*res://scripts/autoload/CoopManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

end_turn={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194309,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

environment/defaults/default_clear_color=Color(0.047, 0.031, 0.027, 1)
